<Page x:Class="Projet_Guichet.AdminInterface"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Projet_Guichet"
      xmlns:UserControls="clr-namespace:Projet_Guichet.View.UserControls"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="AdminInterface"
      Background="White">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="20*" />
            <ColumnDefinition Width="60*" />
            <ColumnDefinition Width="20*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="LightSkyBlue"/>

        <Grid Grid.Column="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition/>
                <RowDefinition/>
                <RowDefinition/>
                <RowDefinition/>
            </Grid.RowDefinitions>

            <UserControls:CustomBtn Grid.Row="0" Grid.Column="0" Margin="10" x:Name="btnCreerClient"
                                        BtnText="Créer un client" Click="btnCreerClient_Click" />
            <UserControls:CustomBtn Grid.Column="1" Grid.Row="0" Margin="10" x:Name="btnCreerCompte"
                                        BtnText="Créer un compte" Click="btnCreerCompte_Click"/>
            <UserControls:CustomBtn Grid.Column="2" Grid.Row="0" Margin="10" x:Name="btnListeClients"
                                        BtnText="Liste des clients" Click="btnListeClients_Click"/>
            <UserControls:CustomBtn Grid.Column="0" Grid.Row="1" Margin="10" x:Name="btnPayerInterets"
                                        BtnText="Payer les intérêts&#10;des comptes épargnes" Click="btnPayerInterets_Click"/>
            <UserControls:CustomBtn Grid.Column="1" Grid.Row="1" Margin="10" x:Name="btnCollecterInterets"
                                        BtnText="Collecter les intérêts&#10;des marges de crédit" Click="btnCollecterInterets_Click"/>
            <UserControls:CustomBtn Grid.Column="2" Grid.Row="1" Margin="10" x:Name="btnPrelevementHypothequaire"
                                        BtnText="Prélevement &#10;Hypothéquaire" Click="btnPrelevementHypothequaire_Click"/>
            <UserControls:CustomBtn Grid.Column="0" Grid.Row="2" Margin="10" x:Name="btnRemplitGuichet"
                                        BtnText="Remplir le guichet" Click="btnRemplitGuichet_Click"/>
            <UserControls:CustomBtn Grid.Column="1" Grid.Row="2" Margin="10" x:Name="btnVoirTransactions"
                                        BtnText="Voir les transactions" Click="btnVoirTransactions_Click"/>
            <UserControls:CustomBtn Grid.Column="2" Grid.Row="2" Margin="10" x:Name="btnListeComptes"
                                        BtnText="Liste des comptes" Click="btnListeComptes_Click"/>
            <UserControls:CustomBtn Grid.Column="0" Grid.Row="3" Margin="10" x:Name="btnFermerGuicher"
                                        BtnText="Fermer le guichet" Click="btnFermerGuicher_Click"/>
            <UserControls:CustomBtn Grid.Column="1" Grid.Row="3" Margin="10" x:Name="btnQuitter"
                                        BtnText="Quitter" Click="btnQuitter_Click"/>

        </Grid>

        <Border Grid.Column="2" Background="LightSkyBlue"/>
    </Grid>
</Page>
