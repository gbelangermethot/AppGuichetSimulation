<Page x:Class="Projet_Guichet.ChoixNIP"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Projet_Guichet"
      xmlns:UserControls="clr-namespace:Projet_Guichet.View.UserControls"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="ChoixNIP">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1*" />
            <ColumnDefinition Width="1*" />
        </Grid.ColumnDefinitions>



        <Grid Grid.Column="0" Background="White">

            <StackPanel Width="250"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center">

                <TextBlock Text="Choisisez votre NIP"
                   FontSize="24"
                   Margin="0,0,0,30"
                   HorizontalAlignment="Center"/>

                <TextBlock Text="Entrez votre NIP"
                       FontSize="16"
                       Margin="0,0,0,5"
                       HorizontalAlignment="Left"/>

                <PasswordBox x:Name="txtNip1" 
                         Height="35"
                         Margin="0,0,0,10"
                         PreviewMouseDown="txtNip1_PreviewMouseDown"/>
                
                <TextBlock Text="Confirmez votre NIP"
                       FontSize="16"
                       Margin="0,0,0,5"
                       HorizontalAlignment="Left"/>

                <PasswordBox x:Name="txtNip2"
                         Height="35"
                         Margin="0,0,0,20"
                         PreviewMouseDown="txtNip2_PreviewMouseDown"/>

                <UserControls:CustomBtn x:Name="btnSoumettre" BtnText="Soumettre" Margin="60,20,60,0" Click="btnSoumettre_Click"/>
            </StackPanel>
        </Grid>

        <Border Grid.Column="1" Background="LightSkyBlue"/>
        <UserControls:numericKeyboard x:Name="MyKeyboard" Grid.Column="1"/>
    </Grid>
</Page>
