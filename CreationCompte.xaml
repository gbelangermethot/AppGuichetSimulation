<Page x:Class="Projet_Guichet.CreationCompte"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Projet_Guichet"
      xmlns:UserControls="clr-namespace:Projet_Guichet.View.UserControls"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="CreationCompte"
      Background="White">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="25*" />
            <ColumnDefinition Width="50*" />
            <ColumnDefinition Width="25*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="LightSkyBlue"/>

        <StackPanel Width="250"
            VerticalAlignment="Center"
            HorizontalAlignment="Center"
            Grid.Column="1">

            <TextBlock Text="Nouveau Compte"
                FontSize="24"
                Margin="0,0,0,20"
                HorizontalAlignment="Center"/>



            <TextBlock Text="Client"
                FontSize="16"
                Margin="0,0,0,5"
                HorizontalAlignment="Left"/>

            <ComboBox x:Name="cmbClient"
                ItemsSource="{Binding ListeUtilisateurs}" 
                DisplayMemberPath="FullDisplayUser" 
                SelectedValuePath="Id"
                Height="35"
                Margin="0,0,0,20">
            </ComboBox>

            <TextBlock Text="Type de compte"
                FontSize="16"
                Margin="0,0,0,5"
                HorizontalAlignment="Left"/>

            <ComboBox x:Name="cmbType"
                ItemsSource="{Binding ListeTypeComptes}" 
                DisplayMemberPath="Description" 
                SelectedValuePath="Id"
                Height="35"
                Margin="0,0,0,20">
            </ComboBox>

            <StackPanel Orientation="Horizontal"
                VerticalAlignment="Center"
                HorizontalAlignment="Center">
                <UserControls:CustomBtn x:Name="btnSoumettre" BtnText="Soumettre" Margin="10" Click="btnSoumettre_Click"/>
                <UserControls:CustomBtn x:Name="btnRetour" BtnText="Retour" Margin="10" Click="btnRetour_Click"/>
            </StackPanel>
        </StackPanel>

        <Border Grid.Column="2" Background="LightSkyBlue"/>
    </Grid>
</Page>
