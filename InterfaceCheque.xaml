<Page x:Class="Projet_Guichet.InterfaceCheque"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Projet_Guichet"
      xmlns:UserControls="clr-namespace:Projet_Guichet.View.UserControls"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="InterfaceCheque">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="25*" />
            <ColumnDefinition Width="50*" />
            <ColumnDefinition Width="25*" />
        </Grid.ColumnDefinitions>
            <Border Grid.Column="0" Background="LightSkyBlue"/>
            <Grid Grid.Column="1" Background="White">
                <Grid.RowDefinitions>
                    <RowDefinition Height="20*"/>
                    <RowDefinition Height="80*"/>
                </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="Compte cheque&#10;" FontSize="24" x:Name="tbEntete"
                       HorizontalAlignment="Center" VerticalAlignment="Center"/>

            <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition/>
                        <RowDefinition/>
                        <RowDefinition/>
                    </Grid.RowDefinitions>
                    <UserControls:CustomBtn Grid.Column="0" Grid.Row="0" Margin="20" x:Name="btnDepot"
                                        BtnText="Dépot" Click="btnDepot_Click"/>
                    <UserControls:CustomBtn Grid.Column="1" Grid.Row="0" Margin="20" x:Name="btnRetrait"
                                        BtnText="Retrait" Click="btnRetrait_Click"/>
                    <UserControls:CustomBtn Grid.Column="0" Grid.Row="1" Margin="20" x:Name="btnTransfer"
                                        BtnText="Transfer vers un&#10; autre compte" Click="btnTransfer_Click"/>
                    <UserControls:CustomBtn Grid.Column="1" Grid.Row="1" Margin="20" x:Name="btnPaiement"
                                        BtnText="Paiment de facture" Click="btnPaiement_Click"/>
                    <UserControls:CustomBtn Grid.Column="0" Grid.Row="2" Margin="20" x:Name="btnTransactions"
                                        BtnText="Voir les transactions" Click="btnTransactions_Click"/>
                    <UserControls:CustomBtn Grid.Column="1" Grid.Row="2" Margin="20" x:Name="btnRetour"
                                        BtnText="Retour" Click="btnRetour_Click"/> 

                </Grid>
            </Grid>
        <Border Grid.Column="2" Background="LightSkyBlue"/>
    </Grid>
</Page>
