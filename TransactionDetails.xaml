<Page x:Class="Projet_Guichet.TransactionDetails"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Projet_Guichet"
      xmlns:UserControls="clr-namespace:Projet_Guichet.View.UserControls"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="TransactionDetails"
      Background="White">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="25*" />
            <ColumnDefinition Width="50*" />
            <ColumnDefinition Width="25*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="LightSkyBlue"/>
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" 
                    BorderBrush="Black" 
                    BorderThickness="1" 
                    HorizontalAlignment="Stretch">

                <TextBlock x:Name="tbEntete"
                           Text="Transaction no: "
                           FontSize="24"
                           Margin="10"
                           HorizontalAlignment="Left"
                           VerticalAlignment="Center"
                           TextWrapping="Wrap"/>
            </Border>

            <Border Grid.Row="1" 
                    BorderBrush="Black" 
                    BorderThickness="1" 
                    HorizontalAlignment="Stretch">
                <TextBlock x:Name="tbCompte"
                           Text="Compte: "
                           FontSize="20"
                           Margin="10"
                           HorizontalAlignment="Left"
                           VerticalAlignment="Center"
                           TextWrapping="Wrap"/>
            </Border>

            <Border Grid.Row="2" 
                    BorderBrush="Black" 
                    BorderThickness="1" 
                    HorizontalAlignment="Stretch">
                <TextBlock x:Name="tbType"
                           Text="Type: "
                           FontSize="20"
                           Margin="10"
                           HorizontalAlignment="Left"
                           VerticalAlignment="Center"
                           TextWrapping="Wrap"/>
            </Border>

            <Border Grid.Row="3" 
                    BorderBrush="Black" 
                    BorderThickness="1" 
                    HorizontalAlignment="Stretch">
                <TextBlock Grid.Row="3" 
                           x:Name="tbMontant"
                           Text="Montant: "
                           FontSize="20"
                           Margin="10"
                           HorizontalAlignment="Left"
                           VerticalAlignment="Center"
                           TextWrapping="Wrap"/>
            </Border>

            <Border Grid.Row="4" 
                    BorderBrush="Black" 
                    BorderThickness="1" 
                    HorizontalAlignment="Stretch">
                <TextBlock Grid.Row="4" 
                           x:Name="tbDate"
                           Text="Date: "
                           FontSize="20"
                           Margin="10"
                           HorizontalAlignment="Left"
                           VerticalAlignment="Center"
                           TextWrapping="Wrap"/>
            </Border>

            <Border Grid.Row="5" 
                    BorderBrush="Black" 
                    BorderThickness="1" 
                    HorizontalAlignment="Stretch">
                <TextBlock Grid.Row="5" 
                           x:Name="tbDescription"
                           Text="Description: "
                           FontSize="20"
                           Margin="10"
                           HorizontalAlignment="Left"
                           VerticalAlignment="Center"
                           TextWrapping="Wrap"/>
            </Border>
        </Grid>
        <Border Grid.Column="2" Background="LightSkyBlue"/>
        <UserControls:CustomBtn Grid.Column="2" x:Name="btnRetour" BtnText="Retour" Margin="10" Click="btnRetour_Click" VerticalAlignment="Bottom"/>
    </Grid>
</Page>
