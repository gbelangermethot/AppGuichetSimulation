<Page x:Class="Projet_Guichet.Transactions"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Projet_Guichet"
      xmlns:UserControls="clr-namespace:Projet_Guichet.View.UserControls"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Transactions"
      Background="White">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Border Grid.Column="0" Background="LightSkyBlue"/>
        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition/>
                <RowDefinition/>
                <RowDefinition/>
                <RowDefinition/>
                <RowDefinition/>
            </Grid.RowDefinitions>
            <StackPanel Grid.Row="0" Orientation="Vertical">
                <TextBlock Text="No Transaction"
                           FontSize="24"
                           Margin="10"/>
                <TextBox x:Name="TransactionIdFilter"
                         TextChanged="Filtre_Changed"
                         Height="40"
                         Margin="10, 0, 10, 0"
                         PreviewMouseDown="TransactionIdFilter_PreviewMouseDown"/>
            </StackPanel>
            <StackPanel Grid.Row="1" Orientation="Vertical">
                <TextBlock Text="No Compte"
                           FontSize="24"
                           Margin="10"/>
                <TextBox x:Name="CompteIdFilter"
                         TextChanged="Filtre_Changed"
                         Height="40"
                         Margin="10, 0, 10, 0"
                         PreviewMouseDown="CompteIdFilter_PreviewMouseDown"/>
            </StackPanel>
            <StackPanel Grid.Row="2" Orientation="Vertical">
                <TextBlock Text="No Utilisateur"
                           FontSize="24"
                           Margin="10"/>
                <TextBox x:Name="UtilisateurIdFilter"
                         TextChanged="Filtre_Changed"
                         Height="40"
                         Margin="10, 0, 10, 0"
                         PreviewMouseDown="UtilisateurIdFilter_PreviewMouseDown"/>
            </StackPanel>
            <StackPanel Grid.Row="3" Orientation="Vertical">
                <TextBlock Text="Type de compte Compte"
                           FontSize="24"
                           Margin="10"/>
                <ComboBox x:Name="TypeFilter"
                          SelectionChanged="Filtre_Changed"
                          Height="40"
                          Margin="10, 0, 10, 0"/>
            </StackPanel>
            <UserControls:CustomBtn Grid.Row="4" x:Name="btnRetour" BtnText="Retour" Margin="10" Click="btnRetour_Click" VerticalAlignment="Bottom"/>
        </Grid>

        
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" 
                       x:Name="tbEntete"
                       Text="Liste des transactions "
                       FontSize="24"
                       Margin="0,20"
                       HorizontalAlignment="Center"/>

            <ListBox Grid.Row="1" 
                     ItemsSource="{Binding MesTransactions}" 
                     SelectionChanged="ListBox_SelectionChanged"
                     HorizontalContentAlignment="Stretch">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Setter Property="Padding" Value="0"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="LightGray"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </ListBox.ItemContainerStyle>

                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <UserControls:ListBtn BtnHeight="50" BtnText="{Binding}" />
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Grid>
        <Border Grid.Column="2" Background="LightSkyBlue"/>
        <UserControls:numericKeyboard x:Name="MyKeyboard" Grid.Column="2"/>
    </Grid>
</Page>
