<Page x:Class="Projet_Guichet.UserInterface"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Projet_Guichet"
      xmlns:UserControls="clr-namespace:Projet_Guichet.View.UserControls"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="UserInterface"
      Background="White">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="25*" />
            <ColumnDefinition Width="50*" />
            <ColumnDefinition Width="25*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="LightSkyBlue"/>

        <Grid Grid.Column="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition/>
                <RowDefinition/>
                <RowDefinition/>
            </Grid.RowDefinitions>

            <UserControls:CustomBtn Grid.Column="0" Grid.Row="0" Margin="20" 
                                       BtnText="Chèque &#10;Solde: " x:Name="btnCheque" Click="btnCheque_Click"/>
            <UserControls:CustomBtn Grid.Column="1" Grid.Row="0" Margin="20"
                                       BtnText="Épargne&#10;Solde: " x:Name="btnEpargne" Click="btnEpargne_Click"/>
            <UserControls:CustomBtn Grid.Column="0" Grid.Row="1" Margin="20"
                                       BtnText="Hypothéquaire&#10;Solde: " x:Name="btnHypothequaire" Click="btnHypothequaire_Click"/>
            <UserControls:CustomBtn Grid.Column="1" Grid.Row="1" Margin="20"
                                       BtnText="Marge de crédit&#10;Solde: " x:Name="btnMargeCredit" Click="btnMargeCredit_Click"/>
            <UserControls:CustomBtn Grid.Column="1" Grid.Row="2" Margin="20"
                                       BtnText="Quitter" x:Name="btnQuitter" Click="btnQuitter_Click"/>
        </Grid>

        <Border Grid.Column="2" Background="LightSkyBlue"/>
    </Grid>
</Page>
