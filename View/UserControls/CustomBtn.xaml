<UserControl x:Class="Projet_Guichet.View.UserControls.CustomBtn"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Projet_Guichet.View.UserControls"
             x:Name="rootElement"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    
    <Border x:Name="MainBorder"
            Background="{Binding BtnBackground, ElementName=rootElement}" 
            CornerRadius="20"
            Cursor="Hand"
            MouseDown="MainBorder_MouseDown"
            MouseEnter="MainBorder_MouseEnter"
            MouseLeave="MainBorder_MouseLeave"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch">

        <Viewbox Margin="10">
            <TextBlock Text="{Binding BtnText, ElementName=rootElement}"
                   Foreground="{Binding BtnForeground, ElementName=rootElement}"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"/>
        </Viewbox>
    </Border>
</UserControl>
