<UserControl x:Class="Projet_Guichet.View.UserControls.ListBtn"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Projet_Guichet.View.UserControls"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <!-- Use a Border instead of a Button -->
    <Border Height="{Binding BtnHeight, RelativeSource={RelativeSource AncestorType=UserControl}}" 
        BorderBrush="Black" 
        BorderThickness="1" 
        Background="White"
        Margin="2"
        >
        
        <TextBlock x:Name="customTb"
        Text="{Binding BtnText, RelativeSource={RelativeSource AncestorType=UserControl}}"
        Foreground="Black"
        HorizontalAlignment="Left"
        VerticalAlignment="Center"/>
    </Border>
</UserControl>



