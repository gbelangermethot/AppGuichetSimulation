<UserControl x:Class="Projet_Guichet.View.UserControls.numericButton"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Projet_Guichet.View.UserControls"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <Button x:Name="customButton"
         Width="{Binding BtnWidth}" 
         Height="{Binding BtnHeight}" 
         BorderThickness="0" 
         Background="Transparent">
            <Border x:Name="customBorder" 
             Background="White"
             CornerRadius="10"
             Width="{Binding BtnWidth}" 
             Height="{Binding BtnHeight}">
                <TextBlock x:Name="customTb"
                 Text="{Binding BtnText}"
                 Foreground="Black"
                 HorizontalAlignment="Center"
                 VerticalAlignment="Center"
                 FontSize="24"/>
            </Border>
        </Button>
    </Grid>
</UserControl>
