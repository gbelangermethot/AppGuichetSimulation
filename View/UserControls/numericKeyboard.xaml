<UserControl x:Class="Projet_Guichet.View.UserControls.numericKeyboard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Projet_Guichet.View.UserControls"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1*"/>
            <ColumnDefinition Width="1*"/>
            <ColumnDefinition Width="1*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="1*"/>
        </Grid.RowDefinitions>
        <local:CustomBtn Grid.Column="0" Grid.Row="0" BtnText="1" BtnBackground="White" Margin="10" BtnForeground="Black" BtnFontsize="24" 
                         x:Name="btn1"  Click="btn1_Click"/>
        <local:CustomBtn Grid.Column="1" Grid.Row="0" BtnText="2" BtnBackground="White" Margin="10" BtnForeground="Black" BtnFontsize="24"
                         x:Name="btn2" Click="btn2_Click"/>
        <local:CustomBtn Grid.Column="2" Grid.Row="0" BtnText="3" BtnBackground="White" Margin="10" BtnForeground="Black" BtnFontsize="24"
                         x:Name="btn3" Click="btn3_Click"/>
        <local:CustomBtn Grid.Column="0" Grid.Row="1" BtnText="4" BtnBackground="White" Margin="10" BtnForeground="Black" BtnFontsize="24"
                         x:Name="btn4" Click="btn4_Click"/>
        <local:CustomBtn Grid.Column="1" Grid.Row="1" BtnText="5" BtnBackground="White" Margin="10" BtnForeground="Black" BtnFontsize="24"
                         x:Name="btn5" Click="btn5_Click"/>
        <local:CustomBtn Grid.Column="2" Grid.Row="1" BtnText="6" BtnBackground="White" Margin="10" BtnForeground="Black" BtnFontsize="24"
                         x:Name="btn6" Click="btn6_Click"/>
        <local:CustomBtn Grid.Column="0" Grid.Row="2" BtnText="7" BtnBackground="White" Margin="10" BtnForeground="Black" BtnFontsize="24"
                         x:Name="btn7" Click="btn7_Click"/>
        <local:CustomBtn Grid.Column="1" Grid.Row="2" BtnText="8" BtnBackground="White" Margin="10" BtnForeground="Black" BtnFontsize="24"
                         x:Name="btn8" Click="btn8_Click"/>
        <local:CustomBtn Grid.Column="2" Grid.Row="2" BtnText="9" BtnBackground="White" Margin="10" BtnForeground="Black" BtnFontsize="24"
                         x:Name="btn9" Click="btn9_Click"/>
        <local:CustomBtn Grid.Column="0" Grid.Row="3" BtnText="Éffacer" BtnBackground="White" Margin="10" BtnForeground="Black" BtnFontsize="24"
                         x:Name="btnEffacer" Click="btnEffacer_Click"/>
        <local:CustomBtn Grid.Column="1" Grid.Row="3" BtnText="0" BtnBackground="White" Margin="10" BtnForeground="Black" BtnFontsize="24"
                         x:Name="btn0" Click="btn0_Click"/>
        <local:CustomBtn Grid.Column="2" Grid.Row="3" BtnText="Corriger" BtnBackground="White" Margin="10" BtnForeground="Black" BtnFontsize="24"
                         x:Name="btnCorriger" Click="btnCorriger_Click"/>
     </Grid>
</UserControl>
